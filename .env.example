# ──────────────────────────────────────────────────────────────────────────
# VC Memory AI — environment configuration
# Copy this file to `.env` and fill in the values, then run `npm run setup`.
# ──────────────────────────────────────────────────────────────────────────

# Local SQLite database (zero-config). Swap for a Postgres URL in production.
DATABASE_URL="file:./dev.db"

# Anthropic Claude — used for extraction, chat reasoning, deal analysis, briefs.
# Get a key at https://console.anthropic.com/
ANTHROPIC_API_KEY="sk-ant-..."

# Voyage AI — used for vector embeddings (semantic search / RAG retrieval).
# Anthropic's recommended embeddings partner. Get a key at https://www.voyageai.com/
VOYAGE_API_KEY="pa-..."

# Optional model overrides (sensible defaults live in src/lib/ai/anthropic.ts).
# ANTHROPIC_MODEL_REASONING="claude-opus-4-8"
# ANTHROPIC_MODEL_FAST="claude-haiku-4-5"
# VOYAGE_MODEL="voyage-3.5"
