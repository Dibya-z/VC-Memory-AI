# ──────────────────────────────────────────────────────────────────────────
# VC Memory AI — environment configuration
# Copy this file to `.env` and fill in the values, then run `npm run setup`.
# ──────────────────────────────────────────────────────────────────────────

# PostgreSQL (Neon free tier — no credit card). From the Neon dashboard:
#   • DATABASE_URL = the POOLED connection string (ends with "-pooler...").
#                    Used by the app at runtime.
#   • DIRECT_URL   = the DIRECT (non-pooled) connection string.
#                    Used by `prisma db push` and `npm run ingest:demo`.
# Use the SAME Neon database for local dev and production (the seed script
# resets it each run, so it's safe to re-seed anytime).
DATABASE_URL="postgresql://USER:PASSWORD@HOST-pooler.REGION.aws.neon.tech/DB?sslmode=require"
DIRECT_URL="postgresql://USER:PASSWORD@HOST.REGION.aws.neon.tech/DB?sslmode=require"

# Groq — used for extraction, chat reasoning, deal analysis, briefs.
# Free tier, no credit card required. Get a key at https://console.groq.com/keys
GROQ_API_KEY="gsk_..."

# Voyage AI — used for vector embeddings (semantic search / RAG retrieval).
# Free tier (200M tokens/month). Get a key at https://www.voyageai.com/
VOYAGE_API_KEY="pa-..."

# Optional model overrides (sensible defaults live in src/lib/ai/llm.ts).
# GROQ_MODEL_REASONING="llama-3.3-70b-versatile"  # or "openai/gpt-oss-120b" for strict JSON
# GROQ_MODEL_FAST="llama-3.1-8b-instant"
# VOYAGE_MODEL="voyage-3.5"
